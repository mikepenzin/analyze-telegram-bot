# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL="rediss://default:password@host:port"

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"

# Bot webhook URL (set to your Railway API service URL)
# Leave empty to use long-polling in development
TELEGRAM_WEBHOOK_URL=""

# ─── Market Data (Massive.com / formerly Polygon.io) ────────────────────────
MASSIVE_API_KEY="your-massive-api-key"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# Model for initial analysis (vision capable)
OPENAI_MODEL="gpt-4o"

# Model for simple follow-ups (cheaper)
OPENAI_FOLLOWUP_MODEL="gpt-4o-mini"

# ─── API Service ──────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"

# Internal secret used by bot → api calls (generate a random string)
INTERNAL_API_SECRET="change-me-random-secret"

# URL of the API service (used by bot service to call it)
API_URL="http://localhost:3001"

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV="development"
